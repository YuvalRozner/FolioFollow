{
  "name": "foliofollow-backend",
  "version": "1.0.0",
  "private": true,
  "description": "FolioFollow backend API server",
  "engines": {
    "node": "22"
  },
  "main": "dist/functions.js",
  "scripts": {
    "dev": "nodemon --watch src --ext ts --exec ts-node --files src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "serve": "firebase emulators:start --only functions"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "express-validator": "^7.2.1",
    "firebase-admin": "^13.5.0",
    "firebase-functions": "^7.2.2",
    "helmet": "^8.1.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/node": "^24.5.2",
    "@types/uuid": "^10.0.0",
    "nodemon": "^3.1.10",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2"
  }
}
